# Environment Variables — CampusTouch Frontend

# ─── Local Development ───────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will NEVER be committed.

# Base URL for the app router (keep as '/' for local dev)
VITE_BASE_URL=/

# ─── CI / CD (GitHub Actions sets these automatically) ───────────────────────
# VITE_BASE_URL is set to '/' in the workflow.
# If you deploy to a GitHub Pages project page (not a user/org page) the
# base must match your repo name, e.g. /campus_touch_frontedn/
